{
  "version": 2,
  "builds": [
    { "src": "api/lineup.py", "use": "@vercel/python" },
    { "src": "api/transaction.py", "use": "@vercel/python" },
    { "src": "api/nfl-draft.py", "use": "@vercel/python" },
    { "src": "api/team-name.py", "use": "@vercel/python" },
    { "src": "api/team-avatar.py", "use": "@vercel/python" },
    { "src": "web/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/lineup", "dest": "/api/lineup.py" },
    { "src": "/api/transaction", "dest": "/api/transaction.py" },
    { "src": "/api/nfl-draft", "dest": "/api/nfl-draft.py" },
    { "src": "/api/team-name", "dest": "/api/team-name.py" },
    { "src": "/api/team-avatar", "dest": "/api/team-avatar.py" },
    {
      "src": "/(data_\\d{4}\\.json)",
      "dest": "/web/$1",
      "headers": { "Cache-Control": "public, max-age=86400, stale-while-revalidate=2592000" }
    },
    {
      "src": "/(data\\.json)",
      "dest": "/web/$1",
      "headers": { "Cache-Control": "public, max-age=60, stale-while-revalidate=300" }
    },
    { "src": "/(.*)", "dest": "/web/$1" }
  ]
}

